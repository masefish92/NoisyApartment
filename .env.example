# Copy this file to .env.local and fill in real values. Never commit .env.local
# or any file containing real secrets/IDs — .gitignore already excludes .env*.

# Newsletter/email list provider subscribe endpoint (see src/lib/newsletter-config.ts).
# Must accept a POST with a JSON body of { "email": string }.
# Example: a Buttondown, ConvertKit, or Mailchimp subscribe webhook URL.
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=

# Google AdSense publisher/client ID (e.g. ca-pub-XXXXXXXXXXXXXXXX). When set, the
# adsbygoogle.js loader script is rendered site-wide from src/app/layout.tsx — needed
# for AdSense site verification/approval. Rendering actual ad units in AdSlot.tsx is a
# separate step; see src/lib/ads-config.ts (AD_NETWORK_ENABLED).
NEXT_PUBLIC_AD_CLIENT_ID=
